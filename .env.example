# ── CLI LLM Provider (first match wins) ─────────────────────────────────────
# Only one provider needs to be set. The CLI auto-detects based on which key
# is present. Uncomment exactly one block — or export the variable in your shell.

# ★ RECOMMENDED: Groq — fast inference, free tier available
#   Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Option 2: Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 3: OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=sk-...

# Option 4: Nebius AI Studio (https://studio.nebius.ai)
# NEBIUS_API_KEY=v1-...

# Option 5: Ollama or any OpenAI-compatible endpoint
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=none   # optional — omit for unauthenticated local endpoints

# ── Optional model override ─────────────────────────────────────────────────
# Override the default model for whichever provider is active.
# LLM_MODEL=llama-3.3-70b-versatile
