# ── LLM Provider (first match wins) ────────────────────────────────────────
# Uncomment exactly one block — or set the variables in your shell.

# Option 1: Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Nebius AI Studio (https://studio.nebius.ai)
# NEBIUS_API_KEY=v1-...

# Option 3: OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=sk-...

# Option 4: Ollama or any OpenAI-compatible endpoint
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=none   # optional — omit for unauthenticated local endpoints

# ── Optional model override ─────────────────────────────────────────────────
# Override the default model for whichever provider is active.
# LLM_MODEL=claude-opus-4-6
