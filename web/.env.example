# ── Web App — Server-side environment ───────────────────────────────────────
# Copy this file to .env.local (never commit .env.local to git).
#
# The web app uses Groq on the server by default — users don't need to bring
# their own key. This key is NEVER exposed to the browser.

# ★ REQUIRED for default Groq backend
#   Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
