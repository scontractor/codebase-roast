{
  "name": "codebase-roast",
  "version": "1.0.0",
  "description": "Roast any GitHub repository with AI-powered technical humor, backed by any LLM provider",
  "bin": {
    "codebase-roast": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
